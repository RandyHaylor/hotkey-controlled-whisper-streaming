#!/bin/bash
# `vtt` entry point: ALWAYS (re)starts a dedicated whisper_streaming server
# in a new gnome-terminal window, runs the hotkey controller in the
# foreground with a sticky banner at the bottom, and ALWAYS shuts the
# server down on exit. Assumes this app is the only consumer of port 43007.

set -e

VTT_REPO_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
SERVER_HOST="${SERVER_HOST:-127.0.0.1}"
SERVER_PORT="${SERVER_PORT:-43007}"
BANNER_HEIGHT=9

kill_any_existing_whisper_streaming_server() {
    pkill -f "whisper_online_server.py" 2>/dev/null || true
    # Also close any leftover gnome-terminal window from a prior server run.
    # Safe because we own that title.
    if command -v wmctrl >/dev/null 2>&1; then
        wmctrl -c "vtt-server" 2>/dev/null || true
    elif command -v xdotool >/dev/null 2>&1; then
        for stale_window_id in $(xdotool search --name "^vtt-server$" 2>/dev/null); do
            xdotool windowclose "$stale_window_id" 2>/dev/null || true
        done
    fi
}

shut_down_app_on_exit() {
    printf '\033[r'
    local banner_first_row_one_based=$(( $(tput lines) - BANNER_HEIGHT + 1 ))
    if (( banner_first_row_one_based < 1 )); then
        banner_first_row_one_based=1
    fi
    tput cup $((banner_first_row_one_based - 1)) 0
    printf '\033[J'
    stty sane
    tput cnorm
    echo "[vtt] shutting down whisper_streaming server..."
    kill_any_existing_whisper_streaming_server
}
trap shut_down_app_on_exit EXIT

# ---- Sticky banner setup FIRST so all subsequent messages flow into the
# rolling/scroll region above the bottom banner. ------------------------
TERMINAL_TOTAL_LINES="$(tput lines)"
SCROLL_REGION_BOTTOM_ROW=$((TERMINAL_TOTAL_LINES - BANNER_HEIGHT))

clear

print_banner_at_bottom() {
    local banner_first_row=$((TERMINAL_TOTAL_LINES - BANNER_HEIGHT + 1))
    tput cup $((banner_first_row - 1)) 0
    printf '%s\n' "============================================================"
    printf '%s\n' " Voice-to-Text (vtt) — global hotkeys (transcript above):"
    printf '%s\n' "============================================================"
    printf '%s\n' "  Ctrl+F7   -> mic -> show in this window only"
    printf '%s\n' "  Ctrl+F8   -> mic dictation, types into focused window"
    printf '%s\n' "  Ctrl+F9   -> system audio -> ~/vtt_recordings/*.txt"
    printf '%s\n' "  Ctrl+F10  -> system audio + mic mixed -> ~/vtt_recordings/*.txt"
    printf '%s\n' "  Ctrl+F11  -> mic -> ~/vtt_recordings/*.txt"
    printf '%s\n' "  Ctrl+F12 = stop  |  Ctrl+C in this terminal = exit"
}
print_banner_at_bottom

printf '\033[1;%dr' "$SCROLL_REGION_BOTTOM_ROW"
tput cup 0 0

# ---- Now do the server lifecycle. Output flows into the scroll region. ----
echo "Starting whisper_streaming server in separate window..."
kill_any_existing_whisper_streaming_server
for waited_seconds in $(seq 1 5); do
    nc -z "$SERVER_HOST" "$SERVER_PORT" 2>/dev/null || break
    sleep 1
done

if command -v gnome-terminal >/dev/null 2>&1; then
    ORIGINAL_FOCUSED_WINDOW_ID=""
    if command -v xdotool >/dev/null 2>&1; then
        ORIGINAL_FOCUSED_WINDOW_ID="$(xdotool getactivewindow 2>/dev/null || true)"
    fi
    # Note: no trailing 'exec bash' — when the server exits (whether via
    # vtt cleanup or a crash), the gnome-terminal window closes too,
    # avoiding "abandoned" empty windows on restart.
    gnome-terminal --title="vtt-server" -- bash -lc \
        "$VTT_REPO_DIR/launch_whisper_streaming_server.sh" \
        >/dev/null 2>&1 &
    if [[ -n "$ORIGINAL_FOCUSED_WINDOW_ID" ]]; then
        ( sleep 0.4
          xdotool windowactivate "$ORIGINAL_FOCUSED_WINDOW_ID" 2>/dev/null || true ) &
    fi
else
    mkdir -p "$HOME/vtt_recordings"
    VTT_SERVER_LOG="$HOME/vtt_recordings/vtt_server_$(date +%Y%m%d_%H%M%S).log"
    echo "(no gnome-terminal; logging server output to $VTT_SERVER_LOG)"
    nohup "$VTT_REPO_DIR/launch_whisper_streaming_server.sh" \
        >"$VTT_SERVER_LOG" 2>&1 &
fi

for waited_seconds in $(seq 1 60); do
    if nc -z "$SERVER_HOST" "$SERVER_PORT" 2>/dev/null; then
        echo "VTT service ready."
        echo "Press a hotkey combo to start live vtt."
        break
    fi
    sleep 1
done
# Note: we don't fail-fast here. If the server still isn't up after 60s,
# the controller's per-mode reachability check will surface the error
# when the user tries to use a mode.

VTT_SUPPRESS_BANNER=1 python3 "$VTT_REPO_DIR/whisper_streaming_hotkey_controller.py"
